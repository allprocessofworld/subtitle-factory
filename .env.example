# ============================================
# 🔧 자막 공장 (Subtitle Factory) 환경변수 설정
# ============================================
# 이 파일을 복사하여 .env.local로 이름을 변경한 후,
# 각 항목에 실제 값을 입력하세요.
# cp .env.example .env.local

# --------------------------------------------
# 1. Google OAuth (로그인용)
# --------------------------------------------
# Google Cloud Console > API 및 서비스 > 사용자 인증정보에서 생성
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# NextAuth.js 설정
# 배포 시 실제 도메인으로 변경 (예: https://subtitle-factory.vercel.app)
NEXTAUTH_URL=http://localhost:3000
# 터미널에서 `openssl rand -base64 32` 명령어로 생성
NEXTAUTH_SECRET=your_nextauth_secret_here

# 로그인 허용 이메일 목록 (쉼표로 구분)
# 여기에 등록된 이메일만 로그인 가능합니다
ALLOWED_EMAILS=ceo@company.com,member1@gmail.com,member2@gmail.com

# --------------------------------------------
# 2. Google Gemini API (1차 번역용 - 가성비 최고)
# --------------------------------------------
# https://aistudio.google.com/apikey 에서 무료 생성
GEMINI_API_KEY=your_gemini_api_key_here

# --------------------------------------------
# 3. Anthropic Claude API (영어 폴리싱용 - 품질 최고)
# --------------------------------------------
# https://console.anthropic.com/settings/keys 에서 생성
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --------------------------------------------
# 4. ElevenLabs API (더빙 음성 생성용)
# --------------------------------------------
# https://elevenlabs.io/app/settings/api-keys 에서 생성
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# --------------------------------------------
# 5. YouTube Data API v3 (영상 정보 가져오기용)
# --------------------------------------------
# Google Cloud Console > API 및 서비스 > 사용자 인증정보 > API 키
# YouTube Data API v3를 활성화해야 합니다
YOUTUBE_API_KEY=your_youtube_api_key_here
